<Window x:Class="FocusMate.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate"
        mc:Ignorable="d"
        Title="Window1" Height="350" Width="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <WrapPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Width="80" Content="Title:" FontSize="16"/>
            <TextBox  x:Name="TaskTitleTextBox" Width="200" TextWrapping="Wrap" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
        </WrapPanel>

        <WrapPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Width="80" Content="Category:" FontSize="16"/>
            <ComboBox x:Name="CategoriesComboBox" HorizontalAlignment="Left" Width="200" Grid.Column="1" VerticalAlignment="Center"/>
        </WrapPanel>

        <WrapPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Width="80" Content="Date:" FontSize="16"/>
            <DatePicker x:Name="DatePicker" FontSize="16" Grid.Column="1" Width="200" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </WrapPanel>

        <Button Grid.Column="1" Content="Save" Grid.Row="5" VerticalAlignment="Center" FontSize="16" Width="150" Height="35" HorizontalAlignment="Center" Click="SaveTaskButtonClick"/>
    </Grid>
</Window>
