<Window x:Class="FocusMate.View.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate.View"
        mc:Ignorable="d"
        Title="Progress" Height="500" Width="800" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="0.3*"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="TasksList" Grid.Row="1" Grid.Column="1" AutoGenerateColumns="True" AutoGeneratingColumn="DataGridAutoGeneratingColumn" CanUserAddRows="false" LoadingRow="ChangeRowsBackground">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="IsHitTestVisible" Value="False"/>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <TextBlock x:Name="NoTasks"  Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="You don't have any tasks yet" VerticalAlignment="Center" FontSize="16"/>

        <WrapPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Center">
            <Label HorizontalAlignment="Center" Width="150" VerticalAlignment="Center" Margin="30,0,0,0" >Stats for the last week:</Label>
            <WrapPanel Width="80" Margin="50,0,50,0" >
                <TextBlock x:Name="SolvedTasksLastWeek" Width="80" Text="0" FontSize="32" TextAlignment="Center" Foreground="#FF60CE18"/>
                <Label Width="80" Foreground="#FF60CE18">Solved tasks</Label>
            </WrapPanel>
            <WrapPanel Width="90" Margin="40,0,0,0">
                <TextBlock x:Name="UnsolvedTasksLastWeek"  Width="90" Text="0" FontSize="32" TextAlignment="Center" VerticalAlignment="Center" Foreground="#FFF72525"/>
                <Label Foreground="#FFF72525">Unsolved tasks</Label>
            </WrapPanel>
        </WrapPanel>

        <WrapPanel Grid.Row="3" Grid.Column="1" VerticalAlignment="Center">
            <Label Width="150" VerticalAlignment="Center" Margin="30,0,0,0">Stats for all time:</Label>
            <WrapPanel Width="80"  Margin="50,0,50,0">
                <TextBlock x:Name="SolvedTasksAllTime" Width="80" Text="0" FontSize="32" TextAlignment="Center" Foreground="#FF60CE18" />
                <Label Foreground="#FF60CE18">Solved tasks</Label>
            </WrapPanel>
            <WrapPanel Width="90"  Margin="40,0,0,0">
                <TextBlock x:Name="UnsolvedTasksAllTime" Width="90" Text="0" FontSize="32" TextAlignment="Center" Foreground="#FFF72525"/>
                <Label Foreground="#FFF72525">Unsolved tasks</Label>
            </WrapPanel>
        </WrapPanel>
    </Grid>
</Window>