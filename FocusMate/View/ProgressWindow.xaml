<Window x:Class="FocusMate.View.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate.View"
        mc:Ignorable="d"
        Title="Progress" Height="500" Width="800" ResizeMode="CanMinimize">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="0.3*"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="TasksList" Grid.Row="1" Grid.Column="1" AutoGeneratingColumn="DataGridAutoGeneratingColumn" LoadingRow="ChangeRowsBackground" 
                  Style="{StaticResource CustomDataGridStyle}" ColumnHeaderStyle="{StaticResource RoundedHeaderStyle}"
                  RowStyle="{StaticResource CustomDataGridRow}" CellStyle="{StaticResource CustomDataGridCell}"/>

        <TextBlock x:Name="NoTasks"  Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="You don't have any tasks yet" VerticalAlignment="Center" FontSize="16"/>

        <WrapPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Center">
            <Label Style="{StaticResource CustomLabel}" Foreground="Gray" Width="180" VerticalAlignment="Center" Margin="20,0,0,0" >Stats for this week:</Label>
            <WrapPanel Width="80" Margin="50,0,50,0" >
                <TextBlock x:Name="SolvedTasksThisWeek" Style="{StaticResource BigNumber}" Foreground="{StaticResource GreenColor}"/>
                <Label Width="80" Foreground="{StaticResource GreenColor}">Solved tasks</Label>
            </WrapPanel>
            <WrapPanel Width="90" Margin="40,0,0,0">
                <TextBlock x:Name="UnsolvedTasksThisWeek" Style="{StaticResource BigNumber}" VerticalAlignment="Center" Foreground="{StaticResource RedColor}"/>
                <Label Foreground="{StaticResource RedColor}">Unsolved tasks</Label>
            </WrapPanel>
        </WrapPanel>

        <WrapPanel Grid.Row="3" Grid.Column="1" VerticalAlignment="Center">
            <Label Style="{StaticResource CustomLabel}" Foreground="Gray" Width="180" VerticalAlignment="Center" Margin="20,0,0,0">Stats for all the time:</Label>
            <WrapPanel Width="80"  Margin="50,0,50,0">
                <TextBlock x:Name="SolvedTasksAllTime" Style="{StaticResource BigNumber}" Foreground="{StaticResource GreenColor}" />
                <Label Foreground="{StaticResource GreenColor}">Solved tasks</Label>
            </WrapPanel>
            <WrapPanel Width="90" Margin="40,0,0,0">
                <TextBlock x:Name="UnsolvedTasksAllTime" Style="{StaticResource BigNumber}" Foreground="{StaticResource RedColor}"/>
                <Label Foreground="{StaticResource RedColor}">Unsolved tasks</Label>
            </WrapPanel>
        </WrapPanel>
    </Grid>
</Window>