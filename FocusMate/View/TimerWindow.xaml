<Window x:Class="FocusMate.TimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate"
        mc:Ignorable="d"
        Title="TimerWindow" Height="400" Width="400" ResizeMode="CanMinimize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <WrapPanel Height="200" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="TimerDisplay" FontSize="72"  Width="300" Text="00:00" TextAlignment="Center"/>
            <TextBlock x:Name="TaskTitle" TextWrapping="Wrap" Width="300" FontSize="24" TextAlignment="Center" Margin="0,30,0,0"/>
        </WrapPanel>
        <WrapPanel Grid.Row="1" VerticalAlignment="Center">
            <Button Content="Stop" FontSize="24" Width="150" Height="50" Click="StopTimerButtonClick" Margin="25,0,0,0"/>
            <Button Content="Continue" FontSize="24" Width="150" Height="50" Click="ContinueTimerButtonClick" Margin="50,0,0,0"/>
        </WrapPanel>
    </Grid>
</Window>
