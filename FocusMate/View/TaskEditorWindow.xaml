<Window x:Class="FocusMate.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate"
        mc:Ignorable="d"
        Title="Task" Height="350" Width="350" ResizeMode="CanMinimize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>


    <Grid Background="{StaticResource PinkGradientWindow}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <WrapPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Content="Title:" Style="{StaticResource CustomLabel}"/>
            <TextBox  x:Name="TaskTitleTextBox" Width="200" TextWrapping="Wrap" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource RoundedTextBoxStyle}"/>
        </WrapPanel>

        <WrapPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Content="Category:" Style="{StaticResource CustomLabel}"/>
            <ComboBox x:Name="CategoriesComboBox" HorizontalAlignment="Left" Width="200" Grid.Column="1" VerticalAlignment="Center" Height="25" Style="{StaticResource RoundedComboBoxStyle}"/>
        </WrapPanel>

        <WrapPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Content="Date:" Style="{StaticResource CustomLabel}"/>
            <Border BorderThickness="1" BorderBrush="#569DE5" Background="White" CornerRadius="8" Padding="5,0,5,0" Width="200" Height="25">
                <DatePicker x:Name="DatePicker" FontSize="14" Grid.Column="1" Width="180" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25" 
                            BorderBrush="{x:Null}" SelectedDateChanged="CheckIfDateInThePast">
                    <DatePicker.Resources>
                        <Style TargetType="DatePickerTextBox">
                            <Setter Property="IsReadOnly" Value="True"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>
            </Border>
        </WrapPanel>

        <Button Grid.Column="1" Content="Save" Grid.Row="5" VerticalAlignment="Center" HorizontalAlignment="Center" Click="SaveTaskButtonClick" Style="{StaticResource BtnPink}"/>
    </Grid>
</Window>
