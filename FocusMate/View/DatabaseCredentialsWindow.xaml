<Window x:Class="FocusMate.View.DatabaseCredentialsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate.View"
        mc:Ignorable="d"
        Title="DatabaseCredentialsWindow" Height="200" Width="320">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <WrapPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Database username:" FontSize="16"/>
            <TextBox x:Name="UsernameTextBox" Width="140" FontSize="16" Height="25"/>
        </WrapPanel>
        <WrapPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label FontSize="16" Content="Database password:"/>
            <PasswordBox FontSize="16" x:Name="PasswordTextBox" Width="140" Height="25"/>
        </WrapPanel>
        <Button FontSize="16" Grid.Row="2" Width="150" Height="30" Content="Save Credentials" Click="SaveCredentials"/>
    </Grid>
</Window>
