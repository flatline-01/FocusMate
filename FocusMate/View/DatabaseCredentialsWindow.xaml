<Window x:Class="FocusMate.View.DatabaseCredentialsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate.View"
        mc:Ignorable="d"
        Title="Credentials" Height="200" Width="320">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource GreenGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <WrapPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Database username:" Style="{StaticResource CustomLabel}" Width="165"/>
            <TextBox x:Name="UsernameTextBox" Width="140" Style="{StaticResource RoundedTextBoxStyle}"/>
        </WrapPanel>
        <WrapPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Database password:" Style="{StaticResource CustomLabel}" Width="160"/>
            <PasswordBox x:Name="PasswordTextBox" Style="{StaticResource RoundedPasswordBoxStyle}" Width="140"/>
        </WrapPanel>
        <Button Grid.Row="2" Content="Save Credentials" Click="SaveCredentials" Style="{StaticResource BtnYellow}" Width="190"/>
    </Grid>
</Window>
