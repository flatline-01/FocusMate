<Window x:Class="FocusMate.CategoryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate"
        mc:Ignorable="d"
        Title="CategoryEditorWindow" Height="400" Width="400" ResizeMode="CanMinimize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate x:Key="EditButtonTemplate">
                <Button x:Name="EditCategoryButton" Click="EditCategoryButtonClick" Style="{StaticResource ButtonWithImageStyle}">
                    <Image Source="/Resource/editIcon.png" Style="{StaticResource Icon}"/>
                </Button>
            </DataTemplate>
            <DataTemplate x:Key="DeleteButtonTemplate">
                <Button x:Name="DeleteCategoryButton" Click="DeleteCategoryButtonClick" Style="{StaticResource ButtonWithImageStyle}">
                    <Image Source="/Resource/trashIcon.png" Style="{StaticResource Icon}"/>
                </Button>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource PurpleGradientWindow}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="0.6*"/>
            <RowDefinition Height="0.8*"/>
        </Grid.RowDefinitions>

        <Label Content="Categories:" Style="{StaticResource CustomLabel}" HorizontalAlignment="Left" Grid.Column="1" Grid.Row="0" VerticalAlignment="Center"/>
        <DataGrid AutoGeneratingColumn="DataGridAutoGeneratingColumn" Name="CategoriesList" HeadersVisibility="All" Style="{StaticResource CustomDataGridStyle}" ColumnHeaderStyle="{StaticResource RoundedHeaderStyle}"
                  RowStyle="{StaticResource CustomDataGridRow}" CellStyle="{StaticResource CustomDataGridCell}" Grid.Column="1" Grid.Row="1"/>

        <TextBlock x:Name="NoCategoriesTextBlock" Text="No categories." FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="1" Grid.Row="1"/>

        <Label Content="Category:" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource CustomLabel}" Grid.Column="1" Grid.Row="2"/>
        <TextBox x:Name="CategoryNameTextBox" TextWrapping="Wrap" VerticalAlignment="Center" Width="175" Style="{StaticResource RoundedTextBoxStyle}" 
                 Grid.Column="1" Grid.Row="2" HorizontalAlignment="Right"/>

        <Button Grid.Row="3" Grid.Column="1" Content="Save" Click="AddNewCategoryButtobClick" VerticalAlignment="Center" HorizontalAlignment="Center" 
                Style="{StaticResource BtnPurple}"/>
    </Grid>
</Window>