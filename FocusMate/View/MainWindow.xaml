<Window x:Class="FocusMate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate"
        mc:Ignorable="d"
        Title="Dashboard" Height="500" Width="800" ResizeMode="CanMinimize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <DataTemplate x:Key="StartButtonTemplate">
                <Button x:Name="StartTaskButton" Click="StartTaskButtonClick" Style="{StaticResource ButtonWithImageStyle}">
                    <Image Source="/Resource/playIcon.png" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </DataTemplate>
            <DataTemplate x:Key="EditButtonTemplate">
                <Button x:Name="EditTaskButton" Click="EditTaskButtonClick" Style="{StaticResource ButtonWithImageStyle}">
                    <Image Source="/Resource/editIcon.png" Style="{StaticResource Icon}"/>
                </Button>
            </DataTemplate>
            <DataTemplate x:Key="DeleteButtonTemplate">
                <Button x:Name="DeleteTaskButton" Click="DeleteTaskButtonClick" Style="{StaticResource ButtonWithImageStyle}">
                    <Image Source="/Resource/trashIcon.png" Style="{StaticResource Icon}"/>
                </Button>
            </DataTemplate>
            <DataTemplate x:Key="CheckBoxTemplate">
                <CheckBox x:Name="CompleteTaskCheckBox" Checked="TaskCompletingHandler" Margin="0,4,0,0"/>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="TasksList" Grid.Row="1" Grid.Column="1" AutoGeneratingColumn="DataGridAutoGeneratingColumn" Style="{StaticResource CustomDataGridStyle}" HeadersVisibility="All" 
                  ColumnHeaderStyle="{StaticResource RoundedHeaderStyle}" RowStyle="{StaticResource CustomDataGridRow}" CellStyle="{StaticResource CustomDataGridCell}">
        </DataGrid>

        <TextBlock x:Name="NoTasks"  Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="You don't have any tasks yet" VerticalAlignment="Center" FontSize="16"/>

        <WrapPanel  Grid.Column="1" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Add Task" Name="AddTaskButton" Click="AddTaskButtonClick" Margin="0,0,30,0" Style="{StaticResource BtnBlue}"/>
            <Button Content="Add Category" Name="AddCategoryButton" Click="AddCategoryButtonClick" Margin="30,0,30,0" Style="{StaticResource BtnYellow}"/>
            <Button Content="View Progress" x:Name="ViewProgressButton" Margin="30,0,0,0" Click="ViewProgressButtonClick" Style="{StaticResource BtnGreen}"/>
        </WrapPanel>
    </Grid>
</Window>
