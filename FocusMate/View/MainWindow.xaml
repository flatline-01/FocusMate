<Window x:Class="FocusMate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="800" ResizeMode="NoResize">
    <Window.Resources>
        <DataTemplate x:Key="StartTaskButtonTemplate">
            <Button x:Name="StartTaskButton" Click="StartTaskButtonClick" Content="Start"/>
        </DataTemplate>
        <DataTemplate x:Key="CompleteTaskCheckBoxTemplate">
            <CheckBox x:Name="CompleteTaskCheckBox" Checked="TaskCompletingHandler"></CheckBox>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="TasksList" Grid.Row="1" Grid.Column="1" AutoGenerateColumns="True" AutoGeneratingColumn="DataGridAutoGeneratingColumn" CanUserAddRows="false"/>

        <TextBlock x:Name="NoTasks"  Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="You don't have any tasks yet" VerticalAlignment="Center" FontSize="16"/>

        <WrapPanel  Grid.Column="1" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Add Task" Name="AddTaskButton" Width="100" Height="30" Click="AddTaskButtonClick" Margin="0,0,30,0"/>
            <Button Content="Add Category" Name="AddCategoryButton" Width="100" Click="AddCategoryButtonClick" Margin="30,0,0,0"/>
        </WrapPanel>
    </Grid>
</Window>
