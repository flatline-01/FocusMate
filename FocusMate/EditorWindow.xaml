<Window x:Class="FocusMate.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FocusMate"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="450">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45*"/>
            <RowDefinition Height="45*"/>
            <RowDefinition Height="45*"/>
            <RowDefinition Height="45*"/>
            <RowDefinition Height="45*"/>
            <RowDefinition Height="45*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*"/>
            <ColumnDefinition Width="75*"/>
        </Grid.ColumnDefinitions>
        
        <Label Content="Title: " HorizontalAlignment="Center"  VerticalAlignment="Center" FontSize="16"/>
        <TextBox HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center" Width="283" FontSize="16" Grid.Column="1" Height="23"/>

        <Label Content="Category: " HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Grid.Row="1"/>
        <ComboBox HorizontalAlignment="Left" VerticalAlignment="Center" Width="120" Grid.Column="1" Height="22" Grid.Row="1"/>

        <Label Content="Date: " HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Grid.Row="2"/>
        <DatePicker HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="16" Grid.Column="1" Height="29" Width="124" Grid.Row="2"/>

        <Label Content="Done:" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Grid.Row="3"/>
        <CheckBox HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="16" Grid.Column="1" Height="15" Width="16" Grid.Row="3"/>

        <Button Grid.Column="1" Content="Save" HorizontalAlignment="Left" Grid.Row="5" VerticalAlignment="Center" FontSize="16" Width="200"/>
    </Grid>
</Window>
